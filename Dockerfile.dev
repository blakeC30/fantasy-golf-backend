FROM python:3.12-slim

WORKDIR /app

# Install uv
RUN pip install uv --quiet

# UV_SYSTEM_PYTHON=1 installs packages into the system Python rather than a
# virtualenv. This prevents the /app volume mount from shadowing the .venv
# directory and breaking all imports at runtime.
ENV UV_SYSTEM_PYTHON=1

# Install dependencies before mounting source code so they are baked into
# the image layer and survive the volume mount.
COPY pyproject.toml .
RUN uv sync

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
